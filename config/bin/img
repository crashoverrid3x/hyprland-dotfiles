#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: img <image-path>"
  exit 1
fi

if command -v imv >/dev/null 2>&1; then
  exec imv "$@"
fi

if command -v kitty >/dev/null 2>&1; then
  exec kitty +kitten icat "$1"
fi

echo "No terminal image viewer found. Install imv."
exit 1
