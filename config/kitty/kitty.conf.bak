# --- Fuentes (Hack Nerd Font) ---
font_family      Hack Nerd Font Mono
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size        13.0

# --- Apariencia 42 Style ---
# background            #1e1e2e
# foreground            #cdd6f4
background_opacity     0.8
window_padding_width   10
cursor_shape          block
shell_integration     no-cursor

# --- Triple Buffer (Múltiples Clipboards) ---
# Fila de números para GUARDAR (Ctrl + Shift + 1, 2, 3)
map ctrl+shift+1 copy_to_buffer a
map ctrl+shift+2 copy_to_buffer b
map ctrl+shift+3 copy_to_buffer c

# Fila QWE para PEGAR (Ctrl + Shift + Q, W, E)
map ctrl+shift+q paste_from_buffer a
map ctrl+shift+w paste_from_buffer b
map ctrl+shift+e paste_from_buffer c

# --- Navegación y Gestión de Ventanas (65% Optimized) ---
map ctrl+shift+enter new_window_with_cwd
map ctrl+shift+t     new_tab_with_cwd
map ctrl+shift+w     close_window
# Moverse entre paneles con Ctrl + Shift + Flechas
map ctrl+shift+left  neighboring_window left
map ctrl+shift+right neighboring_window right
map ctrl+shift+up    neighboring_window up
map ctrl+shift+down  neighboring_window down

# --- Comportamiento ---
copy_on_select yes
enable_audio_bell no
confirm_os_window_close 0

# Recargar configuración con Ctrl + Shift + R
map ctrl+shift+r load_config_file


# BEGIN_KITTY_THEME
# Adwaita dark
include current-theme.conf
# END_KITTY_THEME
