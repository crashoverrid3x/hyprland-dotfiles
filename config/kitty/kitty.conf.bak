###############################################################
#                                                             #
#   crashdev DotFiles configuration for Hyprland              #
#                                                             #
###############################################################

font_family       JetBrainsMono Nerd Font Mono 
enable_ligatures yes
font_size 12

cursor #ad8ee6
cursor_shape block

disable_ligatures never

url_color #61afef

#: The cursor shape can be one of block, beam, underline. Note that
cursor_beam_thickness 1.5
background_opacity 0.88
window_padding_width 8

enable_remote_control yes

# --- Triple Buffer (Múltiples Clipboards) ---
# Fila de números para GUARDAR (Ctrl + Shift + 1, 2, 3)
map alt+1 copy_to_buffer a
map alt+2 copy_to_buffer b
map alt+3 copy_to_buffer c
# Fila QWE para PEGAR (Ctrl + Shift + Q, W, E)
map alt+q paste_from_buffer a
map alt+w paste_from_buffer b
map alt+e paste_from_buffer c

tab_bar_style powerline
inactive_tab_background #e06c75
active_tab_background #98c379
inactive_tab_foreground #000000
tab_bar_margin_color black

[blur]
background=true

foreground #a9b1d6
background #0a0a0f

# Black
color0 #32344a
color8 #444b6a

# Red
color1 #f7768e
color9 #ff7a93

# Green
color2  #9ece6a
color10 #b9f27c

# Yellow
color3  #e0af68
color11 #ff9e64

# Blue
color4  #7aa2f7
color12 #7da6ff

# Magenta
color5  #ad8ee6
color13 #bb9af7

# Cyan
color6  #449dab
color14 #0db9d7

# White
color7  #787c99
color15 #acb0d0
